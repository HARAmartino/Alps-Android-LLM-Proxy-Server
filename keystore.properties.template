# keystore.properties – TEMPLATE
#
# Copy this file to keystore.properties (same directory) and fill in your values.
# keystore.properties is listed in .gitignore and must NEVER be committed to git.
#
# How to generate a new release keystore:
#   keytool -genkeypair \
#     -keystore release.jks \
#     -alias <KEY_ALIAS> \
#     -keyalg RSA \
#     -keysize 2048 \
#     -validity 10000 \
#     -storepass <STORE_PASSWORD> \
#     -keypass  <KEY_PASSWORD>
#
# Place the generated release.jks anywhere on disk (outside the repo is safest)
# and set storeFile below to its absolute path.

storeFile=/path/to/release.jks
storePassword=CHANGE_ME
keyAlias=CHANGE_ME
keyPassword=CHANGE_ME
